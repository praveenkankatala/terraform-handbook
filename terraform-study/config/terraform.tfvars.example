# ---------------------------------------------------------------------------
# config/terraform.tfvars.example
# Copy to terraform.tfvars and edit. Terraform auto-loads terraform.tfvars
# and *.auto.tfvars, overriding variable defaults.
#
# NEVER commit real terraform.tfvars if it contains secrets. The .gitignore
# already excludes *.tfvars (this .example file is the safe, committed pattern).
# For secret values prefer environment variables:  export TF_VAR_db_password=...
# ---------------------------------------------------------------------------

aws_region  = "us-east-1"
aws_profile = "default"

ec2_instance_type = "t3.micro"
ec2_count         = 1

# A list example (complex type)
instance_types = ["t3.micro", "t3.small", "t3.large"]

# A map example (complex type)
common_tags = {
  Environment = "dev"
  Owner       = "platform-team"
}
